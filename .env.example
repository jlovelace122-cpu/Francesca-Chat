# OpenAI API Key — required for AI-powered chat responses
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-

# Turso (libsql) — required for chat session storage & admin dashboard
# You already have this from your Global AI Sentinel HQ setup
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=eyJ...your-auth-token...

# Admin Dashboard — password to access the admin panel
ADMIN_TOKEN=choose-a-strong-password-here
